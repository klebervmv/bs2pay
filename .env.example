# BS2 Pay ADIQ SDK - Variáveis de Ambiente

# Credenciais OAuth2
ADIQ_CLIENT_ID=seu-client-id-aqui
ADIQ_CLIENT_SECRET=seu-client-secret-aqui

# Ambiente: sandbox | homologation | production
ADIQ_ENVIRONMENT=sandbox

# Configurações HTTP
ADIQ_TIMEOUT=30000

# Logging
ADIQ_LOG_LEVEL=info
ADIQ_LOG_SENSITIVE_DATA=false
ADIQ_LOG_FILE=./logs/adiq.log

# Webhook
ADIQ_WEBHOOK_URL=https://seu-dominio.com/webhook/adiq
